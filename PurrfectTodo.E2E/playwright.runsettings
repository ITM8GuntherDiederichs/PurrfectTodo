<RunSettings>
  <TestRunParameters>
    <Parameter name="browser" value="chromium" />
    <Parameter name="headless" value="true" />
    <Parameter name="timeout" value="30000" />
  </TestRunParameters>
  <NUnit>
    <NumberOfTestWorkers>1</NumberOfTestWorkers>
  </NUnit>
</RunSettings>
